{
	"files": {
		"includes": [
			"apps/**/*",
			"packages/**/*",
			"*.json",
			".github/**/*",
			"turbo.json",
			"biome.json",
			"!!**/node_modules/**",
			"!!**/dist/**",
			"!!**/build/**"
		]
	},

	"overrides": [
		{
			"includes": ["apps/**/vite.config.ts", "apps/**/vite.config.*"],
			"linter": {
				"rules": {
					"correctness": {
						"noNodejsModules": "off"
					}
				}
			}
		}
	],

	"formatter": {
		"enabled": true
	},

	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"correctness": {
				"noNodejsModules": "error"
			}
		}
	}
}
