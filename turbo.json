{
	"$schema": "https://turbo.build/schema.json",
	"tasks": {
		"lint": {
			"outputs": []
		},

		"typecheck": {
			"outputs": []
		},

		"build": {
			"dependsOn": ["^build"],
			"outputs": ["dist/**", "build/**", ".next/**", "storybook-static/**"]
		},

		"storybook": {
			"dependsOn": ["^build"],
			"outputs": ["storybook-static/**"]
		},

		"dev": {
			"cache": false,
			"persistent": true
		},

		"clean": {
			"cache": false
		},

		"test": {
			"dependsOn": ["^build"],
			"outputs": []
		}
	}
}