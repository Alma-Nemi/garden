{
	"compilerOptions": {
		"target": "ES2022",
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"types": ["node"],

		"strict": true,
		"skipLibCheck": true,
		"noEmit": true,

		"baseUrl": ".",

		"paths": {
			"@garden/core": ["packages/core/src/index.ts"],
			"@garden/theme": ["packages/theme/src/index.ts"],
			"@garden/ui": ["packages/ui/src/index.ts"]
		}
	}
}